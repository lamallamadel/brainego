# Deployment Configuration Example
# Copy this file to /opt/brainego/env/deploy.env and customize

# Deployment root directory
DEPLOY_ROOT="/opt/brainego"

# Production environment file (application secrets, configs)
ENV_FILE="/opt/brainego/env/prod.env"

# Smoke Test Configuration
SMOKE_TEST_BASE_URL="http://localhost:8000"
SMOKE_TEST_WORKSPACE_ID="default"
SMOKE_TEST_AUTH_TOKEN=""  # Optional: Bearer token for authenticated tests

# Optional: Prometheus monitoring
PROMETHEUS_URL=""  # Example: http://prometheus:9090

# Optional: Kong Admin API
KONG_ADMIN_URL=""  # Example: http://kong-admin:8001

# Optional: Slack webhook for deployment notifications
SLACK_WEBHOOK_URL=""  # Example: https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Usage:
# 1. Copy this file: cp scripts/deploy/deploy.env.example /opt/brainego/env/deploy.env
# 2. Edit values: vim /opt/brainego/env/deploy.env
# 3. Source before deployment: source /opt/brainego/env/deploy.env
# 4. Run deployment: sudo -E bash scripts/deploy/deploy_vm.sh deploy <sha>
