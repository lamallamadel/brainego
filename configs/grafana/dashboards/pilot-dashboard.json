          "range": true,
          "refId": "A"
        },
        {
          "editorMode": "code",
          "expr": "histogram_quantile(0.95, sum(rate(api_usage_latency_seconds_bucket{workspace_id=~\"$workspace\"}[5m])) by (le, workspace_id))",
          "legendFormat": "p95 {{workspace_id}}",
          "range": true,
          "refId": "B"
