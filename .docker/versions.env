# Docker Global Versions Registry
# ~/.docker/versions.env
# Used by all docker-compose files as defaults
# Project-level .env.docker overrides these values

# Base OS / Python Images
PYTHON_VERSION=3.11
UBUNTU_VERSION=24.04

# Inference & ML Services
MODULAR_MAX_VERSION=latest
MODULAR_MAX_NVIDIA_FULL_VERSION=latest

# Databases & Caches
POSTGRES_VERSION=15-alpine
POSTGRES_PHASE1_VERSION=16-alpine
REDIS_VERSION=7-alpine
QDRANT_VERSION=latest
NEO4J_VERSION=5.15-community
NEO4J_PHASE1_VERSION=5-community
MINIO_VERSION=latest

# Observability & Monitoring
JAEGER_VERSION=1.52
PROMETHEUS_VERSION=v2.48.0
PUSHGATEWAY_VERSION=v1.6.2
GRAFANA_VERSION=10.2.2
LOKI_VERSION=2.9.3
PROMTAIL_VERSION=2.9.3
OTEL_COLLECTOR_VERSION=0.91.0
ALERTMANAGER_VERSION=v0.26.0

# Exporters
REDIS_EXPORTER_VERSION=v1.55.0
POSTGRES_EXPORTER_VERSION=v0.15.0
NVIDIA_GPU_EXPORTER_VERSION=1.2.0

# ML Models (MAX Serve)
MAX_SERVE_PORT=8080
MAX_SERVE_MODEL_PATH=/models/llama-3.3-8b-instruct-q4_k_m.gguf
MAX_SERVE_MAX_BATCH_SIZE=32
MAX_SERVE_MAX_WAITING_TIME_MS=10
MAX_SERVE_MAX_TOKENS=2048

# Database Credentials (Test/Dev Defaults)
POSTGRES_DB=ai_platform
POSTGRES_USER=ai_user
POSTGRES_PASSWORD=ai_password
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
NEO4J_AUTH=neo4j/neo4j_password
QDRANT_API_KEY=

# Ports
QDRANT_HTTP_PORT=6333
QDRANT_GRPC_PORT=6334
REDIS_PORT=6379
POSTGRES_PORT=5432
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
NEO4J_BOLT_PORT=7687
NEO4J_HTTP_PORT=7474

# API Server Ports
API_SERVER_PORT=8000
GATEWAY_PORT=9002
MCPJUNGLE_GATEWAY_PORT=9100
EMBEDDING_SERVICE_PORT=8003

# Observability Ports
PROMETHEUS_PORT=9090
PUSHGATEWAY_PORT=9091
GRAFANA_PORT=3000
JAEGER_UI_PORT=16686
LOKI_PORT=3100

# GPU Support
NVIDIA_VISIBLE_DEVICES=all
CUDA_VISIBLE_DEVICES=0

# Telemetry
ENABLE_TELEMETRY=true
OTLP_ENDPOINT=http://otel-collector:4317
JAEGER_ENDPOINT=jaeger:6831
